# =============================================================================
# AuraPost AI — Environment Variables
# See DEPLOYMENT/REQUIRED_ENV_VARIABLES.md for full detail on every variable
# below, including which are truly mandatory vs. which unlock a specific
# feature (and what happens — an honest error, never a fabricated result — if
# a feature's variable is left unset).
# =============================================================================

# ---- MANDATORY: the app refuses to start without these ----

# PostgreSQL connection string. PostgreSQL is the only supported database
# backend (see POSTGRESQL_CUTOVER_REPORT.md) — there is no SQLite fallback.
DATABASE_URL="postgresql://user:password@localhost:5432/aurapost"

# Generate with: openssl rand -base64 48
JWT_SECRET=""
# Must differ from JWT_SECRET. Generate with: openssl rand -base64 48
JWT_REFRESH_SECRET=""
# Generate with: openssl rand -base64 32. Protects AI provider keys and all
# stored Shopify/social OAuth tokens (AES-256-GCM).
ENCRYPTION_MASTER_KEY=""

# ---- PostgreSQL connection tuning (optional) ----
PG_POOL_MAX=10
PG_POOL_IDLE_TIMEOUT_MS=30000
PG_POOL_CONN_TIMEOUT_MS=5000
# Set to "false" to disable SSL (e.g. local/Docker-network Postgres with no TLS)
PG_SSL=true

# ---- PayPal (primary payment processor) ----
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
# From the PayPal Developer Dashboard, after registering your webhook endpoint
PAYPAL_WEBHOOK_ID=""
# "sandbox" or "live"
PAYPAL_ENV=sandbox
# Optional: pre-created Billing Plan IDs to avoid dynamic Plan creation.
# Pattern: PAYPAL_{PLAN}_{INTERVAL}_PLAN_ID, e.g.:
# PAYPAL_STARTER_MONTHLY_PLAN_ID=""
# PAYPAL_PRO_MONTHLY_PLAN_ID=""
# PAYPAL_ENTERPRISE_YEARLY_PLAN_ID=""

# ---- Stripe (secondary/legacy payment processor, still supported) ----
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_STARTER_MONTHLY_PRICE_ID=""
STRIPE_STARTER_YEARLY_PRICE_ID=""
STRIPE_PRO_MONTHLY_PRICE_ID=""
STRIPE_PRO_YEARLY_PRICE_ID=""
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=""
STRIPE_ENTERPRISE_YEARLY_PRICE_ID=""

# ---- AI Providers (each optional; each fails with a clear, honest error if unset — never a fabricated response) ----
OPENAI_API_KEY=""
OPENAI_IMAGES_API_KEY=""
GEMINI_API_KEY=""
GEMINI_IMAGES_API_KEY=""
DEEPSEEK_API_KEY=""
STABILITY_API_KEY=""
FLUX_API_KEY=""

# ---- Video Providers (each optional; each fails honestly if unset) ----
VEO_API_KEY=""
RUNWAY_API_KEY=""
KLING_ACCESS_KEY=""
KLING_SECRET_KEY=""
# Set to "true" to use real video provider API calls instead of the sandbox/test path
VIDEO_PROVIDER_LIVE=false

# ---- Shopify ----
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""
# Gates the synthetic sandbox sync fallback used only for local dev/testing —
# leave unset (or "false") in any real deployment.
SHOPIFY_SYNC_TEST_MODE=false

# ---- Meta (Facebook & Instagram) ----
META_APP_ID=""
META_APP_SECRET=""
# Set to "true" to allow publishing live to connected Facebook & Instagram
# accounts. When false, actual publish attempts are blocked.
SOCIAL_PUBLISH_LIVE=false

# ---- Application ----
NODE_ENV=production
# Base URL used to build OAuth redirect URIs (Meta, Shopify, PayPal) — set
# this to your real public HTTPS URL in any deployed environment.
APP_URL=""
# Cosmetic flag surfaced by /api/health; does not disable any security checks.
TEST_MODE=false

# ---- Observability (optional) ----
# If set, uncaught errors are also reported to Sentry.
SENTRY_DSN=""
