# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ENCRYPTION_MASTER_KEY: Used for encrypting and decrypting sensitive database values.
# In production, this should be a strong, random 32-character or longer string.
ENCRYPTION_MASTER_KEY=""

# TEST_MODE: Disables credit constraints and grants trial balances for pre-production testing.
TEST_MODE=true

# Meta App Configuration for Facebook & Instagram OAuth Integration
META_APP_ID=""
META_APP_SECRET=""

# SOCIAL_PUBLISH_LIVE: Set to true to allow publishing posts live to connected Facebook & Instagram channels.
# When false, actual publishing attempts will be blocked by safety constraints.
SOCIAL_PUBLISH_LIVE=true



